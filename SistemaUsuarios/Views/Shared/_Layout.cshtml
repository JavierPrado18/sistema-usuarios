<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Perfil CEPLAN</title>
    <!-- Bootstrap-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Fonts -->
    <link href="https://fonts.cdnfonts.com/css/qanelas" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <style>
        body { 
            background-color: #e9ecef; 
        }
        .ceplan-red { background-color: #a42125 !important; }
        .ceplan-logo-font { font-family: 'Arial Black', Gadget, sans-serif; font-style: italic; font-weight: 900; letter-spacing: -1px; }
    </style>
</head>
<body class="bg-light">
    <header class="navbar ceplan-red sticky-top flex-nowrap p-0 shadow text-white" style="height: 60px; z-index: 1050; margin-left: 4rem; width: calc(100% - 4rem);">
        <a class="me-0 px-3 d-flex align-items-center text-decoration-none flex-shrink-0" href="#">
            <img src="/images/ceplan.webp" alt="CEPLAN" style="height: 40px; object-fit: contain;" />
        </a>
        <div class="d-flex flex-grow-1 align-items-center justify-content-end">
            
            

            <div class="d-flex flex-shrink-0 align-items-center pe-3 pe-md-4 gap-3">
                <i class="bi bi-question fs-5 fw-bold" style="cursor: pointer;"></i>
                
                <div class="position-relative" style="cursor: pointer;">
                    <i class="bi bi-bell-fill fs-5"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary px-1" style="font-size: 0.6rem;">
                        9+
                    </span>
                </div>
                
                <div class="d-flex align-items-center d-none d-sm-flex ms-2">
                    <i class="bi bi-person-fill fs-4 me-2"></i>
                    <div class="lh-sm text-end" style="font-size: 0.85rem;">
                        <div class="fw-bold">Osorio Montes, Adriana</div>
                        <div class="text-white-50" style="font-size: 0.75rem;">Operador</div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid p-0">
        <div class="d-flex">
            <partial name="_SidebarPartial" />

            <main class="flex-grow-1 d-flex flex-column bg-light" style="min-height: calc(100vh - 60px); width: calc(100% - 4rem); margin-left: 4rem;">
                <div class="p-3 p-md-4 flex-grow-1">
                    @RenderBody()
                </div>
                <footer class="mt-auto d-flex justify-content-start align-items-center bg-white w-100 ps-4 border-top border-light" style="height: 72px;">
                    <div class="d-flex align-items-center text-secondary p-1" style="font-size: 0.75rem;">
                        <img src="/images/bandera.webp" alt="Logo" class="img-fluid" style="height: 44px;" />
                        <div class="bg-danger text-white px-1 py-1 fw-light me-1 d-flex align-items-center" style="height: 44px;">PERÚ</div>
                        <div class="text-white d-flex align-items-center ps-1 fw-light" style="font-size: 10px; line-height: 1; width: 142px; height: 44px; background-color: #595A5C;">
                            Presidencia<br />del Consejo de<br />Ministros
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center text-white p-1 fw-light ms-1" style="font-size: 10px; line-height: 1; width: 142px; height: 44px; background-color: #9A9B9C;">
                        <div class="px-1" style="line-height: 1;">
                            Centro Nacional<br />de Planeamiento<br />Estratégico
                        </div>
                    </div>
                </footer>
            </main>
        </div>
    </div>

    @await RenderSectionAsync("Modals", required: false)

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>